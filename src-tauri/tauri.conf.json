{
  "$schema": "https://raw.githubusercontent.com/niceholman/schemas/main/tauri/tauri.conf.json",
  "productName": "雨课堂助手",
  "version": "2.1.1",
  "identifier": "com.raincourse.helper",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "雨课堂助手 v2",
        "width": 1100,
        "height": 750,
        "resizable": true,
        "center": true,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
